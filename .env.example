# MCP Codebase Browser - SSE Configuration
# Copy this file to .env and configure for your environment
# NEVER commit .env to version control

# ============================================
# SERVER SETTINGS
# ============================================

# Server port for SSE endpoint
SSE_PORT=9051

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
SSE_HOST=0.0.0.0

# ============================================
# SSL/TLS CONFIGURATION (Optional)
# ============================================
# Leave empty or comment out to disable SSL

# Path to SSL certificate file (absolute or relative to script directory)
# SSL_CERT_PATH=./certs/cert.pem

# Path to SSL key file (absolute or relative to script directory)
# SSL_KEY_PATH=./certs/key.pem

# ============================================
# LOGGING
# ============================================

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Enable request/response logging
DEBUG_LOGGING=false

# ============================================
# TUNNELING (Optional - for remote access)
# ============================================
# Leave empty or comment out to disable tunneling

# Tunnel service: serveo.net, localhost.run, or ngrok
# TUNNEL_SERVICE=serveo.net

# Tunnel subdomain (for serveo.net: http://subdomain.serveo.net)
# TUNNEL_SUBDOMAIN=mcpcodebasebrowser

# Enable automatic tunneling on startup
# ENABLE_TUNNEL=false

# ============================================
# CORS SETTINGS
# ============================================

# Allow all origins (for development only, restrict in production)
# CORS_ALLOW_ALL=true

# Specific allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com
